{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": [
    ".github/workflows/**/*.yml",
    ".github/workflows/**/*.yaml",
    "suite/**/doctype/**/*.js"
  ],
  "tags": [
    "-lintignore"
  ],
  "workspaces": {
    "frontend": {
      "entry": ["src/main.ts", "vite.config.ts"],
      "project": ["src/**/*.{ts,tsx,vue}", "!src/main.ts"],
      "ignoreUnresolved": ["~icons/lucide/*", "unplugin-icons/types/vue"]
    },
    "suite/meet/e2e": {
      "project": [
        "fixtures/**/*.ts",
        "helpers/**/*.ts",
        "specs/**/*.ts",
        "!playwright.config.ts"
      ]
    },
    "suite/meet/sfu-server": {
      "entry": ["src/server.ts", "src/**/*.test.ts"],
      "project": ["src/**/*.ts", "!src/server.ts", "!src/**/*.test.ts"],
      "vitest": false,
      "ignoreBinaries": ["vitest"],
      "ignoreIssues": {
        "src/types/index.ts": ["types"]
      }
    },
    "suite/sheets/collab-server": {
      "project": ["test/**/*.js", "!index.js"]
    }
  }
}

# ==============================================================================
# Frappe Meet — Deployment Configuration
# ==============================================================================
# Copy this file to .env and fill in the values before running deploy.sh
#
#   cp .env.example .env
#   nano .env
#   ./deploy.sh setup
# ==============================================================================

# === Domain & SSL =============================================================
# Domain for Frappe Meet (A record must point to this server).
# The SFU is served at https://DOMAIN/sfu/ — no separate subdomain needed.
DOMAIN=meet.example.com

# Email for Let's Encrypt certificate notifications.
SSL_EMAIL=admin@example.com

# === Frappe ===================================================================
FRAPPE_IMAGE=ghcr.io/frappe/meet:latest
ADMIN_PASSWORD=change-me
SITE_NAME=meet.example.com

# === Database =================================================================
DB_ROOT_PASSWORD=change-me
DB_PASSWORD=change-me

# === SFU Server ===============================================================
SFU_IMAGE=ghcr.io/frappe/meet/sfu-server:latest

# JWT secret — shared between Frappe and the SFU server.
# Generate one with: openssl rand -base64 32
SFU_SECRET=change-me-to-a-strong-random-string

# Your server's PUBLIC IP address. Clients use this for WebRTC media.
# Find it: curl -4 ifconfig.me
WEBRTC_ANNOUNCED_IP=

# UDP port range for WebRTC media. ~2 ports per participant per media track.
RTC_MIN_PORT=40000
RTC_MAX_PORT=40200

# === Optional =================================================================
# MEDIASOUP_NUM_WORKERS=        # Auto-detect from CPU cores
# SFU_LOG_LEVEL=info
# MEDIASOUP_WORKER_LOGLEVEL=warn

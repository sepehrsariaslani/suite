{
	"name": "meet-sfu-server",
	"version": "0.1.0",
	"description": "SFU server for Frappe Meet",
	"main": "dist/sfu-server/src/server.js",
	"scripts": {
		"build": "tsc",
		"start": "node dist/sfu-server/src/server.js",
		"dev": "node --env-file=.env node_modules/.bin/ts-node src/server.ts",
		"dev:watch": "nodemon",
		"spawn-fake": "node --env-file=.env scripts/spawn-fake-users.js",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format .",
		"format:write": "biome format --write .",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"keywords": [
		"mediasoup",
		"webrtc",
		"sfu",
		"video-conferencing"
	],
	"author": "Frappe",
	"license": "AGPL-3.0",
	"packageManager": "yarn@1.22.22",
	"dependencies": {
		"express": "^4.18.2",
		"jsonwebtoken": "^9.0.2",
		"mediasoup": "^3.19.19",
		"socket.io": "^4.7.5",
		"socket.io-client": "^4.7.5"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@types/express": "^4.17.21",
		"@types/jsonwebtoken": "^9.0.6",
		"@types/node": "^20.11.24",
		"nodemon": "^3.0.1",
		"ts-node": "^10.9.2",
		"typescript": "^5.3.3",
		"vitest": "^4.1.6"
	}
}

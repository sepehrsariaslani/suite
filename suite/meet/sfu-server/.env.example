# SFU Server Environment Configuration
# Copy this file to .env and update the values

# JWT Secret for authentication (MUST match Frappe site config sfu_secret)
JWT_SECRET=your_jwt_secret_here

# Server settings
PORT=3000
HOST=localhost

# Mediasoup settings
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=127.0.0.1

# Worker settings
MEDIASOUP_NUM_WORKERS=2
MEDIASOUP_WORKER_LOGLEVEL=warn

# WebRTC settings
WEBRTC_LISTEN_IP=0.0.0.0
WEBRTC_ANNOUNCED_IP=127.0.0.1

# Port ranges for WebRTC
RTC_MIN_PORT=40000
RTC_MAX_PORT=49999

# TURN server settings (optional)
# TURN_SERVER_URL=turn:your-turn-server.com:3478
# TURN_USERNAME=username
# TURN_PASSWORD=password

# Legacy settings (for backward compatibility)
API_KEY=your-api-key-here
SECRET_KEY=your-secret-key-here

# Logging
LOG_LEVEL=debug

# Production example:
# JWT_SECRET=your_strong_random_secret_here
# WEBRTC_ANNOUNCED_IP=your.public.ip.address
# MEDIASOUP_ANNOUNCED_IP=your.public.ip.address

{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": [
    ".github/workflows/e2e.yml",
    "meet/meet/doctype/**/*.js",
    "realtime/handlers.js"
  ],
  "tags": [
    "-lintignore"
  ],
  "workspaces": {
    "e2e": {
      "entry": "playwright.config.ts",
      "project": [
        "fixtures/**/*.ts",
        "helpers/**/*.ts",
        "specs/**/*.ts",
        "!playwright.config.ts"
      ]
    },
    "frontend": {
      "entry": "src/main.ts",
      "project": ["src/**/*.{ts,vue}", "!src/main.ts"],
      "ignoreUnresolved": ["~icons/lucide/*"]
    },
    "sfu-server": {
      "entry": "src/server.ts",
      "project": ["src/**/*.ts", "!src/server.ts"]
    }
  }
}

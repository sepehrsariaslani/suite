#. Description of the 'Recurrence Rule' (JSON) field in DocType 'Calendar
#. Event'
#: mail/client/doctype/calendar_event/calendar_event.json
msgid ""
"Defines how the event repeats over time.\n"
"<br><br>\n"
"Example: \n"
"<pre>{\n"
"  \"frequency\": \"yearly\", \n"
"  /*\n"
"    REQUIRED.\n"
"    Allowed values:\n"
"      \"yearly\", \"monthly\", \"weekly\", \"daily\",\n"
"      \"hourly\", \"minutely\", \"secondly\"\n"
"  */\n"
"\n"
"  \"interval\": 1,\n"
"  /*\n"
"    OPTIONAL.\n"
"    Integer ≥ 1.\n"
"    Repeats every N units of `frequency`.\n"
"  */\n"
"\n"
"  \"count\": 10,\n"
"  /*\n"
"    OPTIONAL.\n"
"    Integer ≥ 1.\n"
"    Number of total occurrences.\n"
"    MUTUALLY EXCLUSIVE with `until`.\n"
"  */\n"
"\n"
"  \"until\": \"2026-12-31T23:59:59Z\",\n"
"  /*\n"
"    OPTIONAL.\n"
"    UTC date-time only (RFC 3339).\n"
"    MUTUALLY EXCLUSIVE with `count`.\n"
"  */\n"
"\n"
"  \"firstDayOfWeek\": \"mo\",\n"
"  /*\n"
"    OPTIONAL.\n"
"    Allowed values:\n"
"      \"mo\", \"tu\", \"we\", \"th\", \"fr\", \"sa\", \"su\"\n"
"  */\n"
"\n"
"  \"bySecond\": [0, 30],\n"
"  /*\n"
"    OPTIONAL.\n"
"    Each value: 0–60\n"
"  */\n"
"\n"
"  \"byMinute\": [0, 15, 30, 45],\n"
"  /*\n"
"    OPTIONAL.\n"
"    Each value: 0–59\n"
"  */\n"
"\n"
"  \"byHour\": [9, 12, 18],\n"
"  /*\n"
"    OPTIONAL.\n"
"    Each value: 0–23\n"
"  */\n"
"\n"
"  \"byDay\": [\n"
"    \"mo\",\n"
"    \"we\",\n"
"    \"fr\",\n"
"    \"1mo\",\n"
"    \"-1fr\"\n"
"  ],\n"
"  /*\n"
"    OPTIONAL.\n"
"    Allowed values:\n"
"      \"mo\"  – Monday\n"
"      \"tu\"  – Tuesday\n"
"      \"we\"  – Wednesday\n"
"      \"th\"  – Thursday\n"
"      \"fr\"  – Friday\n"
"      \"sa\"  – Saturday\n"
"      \"su\"  – Sunday\n"
"\n"
"    Positional weekdays (monthly/yearly only):\n"
"      \"1mo\"   → first Monday\n"
"      \"2tu\"   → second Tuesday\n"
"      \"-1fr\"  → last Friday\n"
"  */\n"
"\n"
"  \"byMonthDay\": [1, 15, -1],\n"
"  /*\n"
"    OPTIONAL.\n"
"    Values:\n"
"      1–31   → day of month\n"
"      -1     → last day of month\n"
"      -2     → second-to-last day\n"
"  */\n"
"\n"
"  \"byYearDay\": [1, 100, -1],\n"
"  /*\n"
"    OPTIONAL.\n"
"    Values:\n"
"      1–366  → day of year\n"
"      -1     → last day of year\n"
"  */\n"
"\n"
"  \"byWeekNo\": [1, 26, 52, -1],\n"
"  /*\n"
"    OPTIONAL.\n"
"    ISO week numbers.\n"
"    Values:\n"
"      1–53\n"
"      -1 → last week of year\n"
"    VALID ONLY when frequency = \"yearly\"\n"
"  */\n"
"\n"
"  \"byMonth\": [1, 6, 12],\n"
"  /*\n"
"    OPTIONAL.\n"
"    Values:\n"
"      1  → January\n"
"      6  → June\n"
"      12 → December\n"
"  */\n"
"\n"
"  \"bySetPosition\": [1, -1]\n"
"  /*\n"
"    OPTIONAL.\n"
"    Selects specific occurrences AFTER all other rules are applied.\n"
"    Values:\n"
"      Positive → nth occurrence\n"
"      Negative → nth-from-last occurrence\n"
"  */\n"
"}\n"
"</pre>"
msgstr ""

